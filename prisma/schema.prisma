generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  nom       String
  adresse   String
  ville     String
  cp        String
  pays      String
  marketingConsent Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
}

model Order {
  id               String   @id // = Stripe session ID (cs_...)
  createdAt        DateTime @default(now())
  amountTotal      Int // centimes
  currency         String   @default("eur")
  paymentStatus    String // "paid" | "unpaid"
  items            Json // [{ slug, nom, prix, quantity, poids }]
  shippingMethod   String
  shippingMethodId String
  shippingCost     Int      @default(0) // centimes
  trackingNumber   String?
  shippingStatus   String   @default("label_created") // label_created | pending_manual | shipped | delivered
  paymentIntentId  String?
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Int // centimes
  category    String // "stock" | "frais" | "marketing" | "autre"
  date        DateTime
  createdAt   DateTime @default(now())
}

model ProductMeta {
  slug  String  @id
  badge String?
}

model ShippingRate {
  id          String @id @default(cuid())
  country     String // "FR", "BE", "LU", etc.
  maxWeightKg Float  // borne supérieure du palier en kg
  priceEur    Float  // prix TTC en euros
  minDays     Int
  maxDays     Int
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  url         String   // Vercel Blob URL
  thumbnail   String   @default("") // Vercel Blob URL
  duration    String   @default("") // ex: "3:42"
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}
